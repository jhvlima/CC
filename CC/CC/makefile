# Comando do compilador Java
JAVAC=javac
# Comando da JVM
JAVA=java
# ROOT ﾂｴe a raiz dos diretﾂｴorios com todos os roteiros de laboratﾂｴorios
ROOT=/home/CC/
# Caminho para o JAR do ANTLR em labs/tools
ANTLR_PATH=./tools/antlr-4.13.2-complete.jar
# Opcﾂｸﾋ彗o de configuracﾂｸﾋ彗o do CLASSPATH para o ambiente Java
CLASS_PATH_OPTION=-cp .:$(ANTLR_PATH)
# Configuracﾂｸﾋ彗o do comando de compilacﾂｸﾋ彗o do ANTLR
ANTLR4=$(JAVA) -jar $(ANTLR_PATH)
# Configuracﾂｸﾋ彗o do ambiente de teste do ANTLR
GRUN=$(JAVA) $(CLASS_PATH_OPTION) org.antlr.v4.gui.TestRig
# Nome da gramﾂｴatica
GRAMMAR_NAME=Exemplo01
# Diretﾂｴorio para aonde vﾋ彗o os arquivos gerados
GEN_PATH=lexer
# Executa o ANTLR e o compilador Java
all: antlr javac
	@echo "Done."

# Executa o ANTLR para compilar a gramﾂｴatica
antlr: $(GRAMMAR_NAME).g
$(ANTLR4) -o $(GEN_PATH) $(GRAMMAR_NAME).g
# Executa o javac para compilar os arquivos gerados
javac:
$(JAVAC) $(CLASS_PATH_OPTION) $(GEN_PATH)/*.java
# Executa o lexer. Comando: $ make run FILE=arquivo_de_teste
run:
cd $(GEN_PATH) && $(GRUN) $(GRAMMAR_NAME) tokens -tokens $(FILE)
# Remove os arquivos gerados pelo ANTLR
clean:
@rm -rf $(GEN_PATH)